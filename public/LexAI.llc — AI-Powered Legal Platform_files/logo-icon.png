    <div style="background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:20px 28px;text-align:center;min-width:120px">
      <div style="font-size:28px;margin-bottom:8px">🇪🇺</div>
      <div style="font-family:var(--mono);font-size:11px;color:#fff;font-weight:600">GDPR</div>
      <div style="font-size:10px;color:var(--muted);margin-top:4px">Compliant</div>
    </div>
    <div style="background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:20px 28px;text-align:center;min-width:120px">
      <div style="font-size:28px;margin-bottom:8px">🔒</div>
      <div style="font-family:var(--mono);font-size:11px;color:#fff;font-weight:600">ISO 27001</div>
      <div style="font-size:10px;color:var(--muted);margin-top:4px">Certified</div>
    </div>
    <div style="background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:20px 28px;text-align:center;min-width:120px">
      <div style="font-size:28px;margin-bottom:8px">🇺🇸</div>
      <div style="font-family:var(--mono);font-size:11px;color:#fff;font-weight:600">CCPA</div>
      <div style="font-size:10px;color:var(--muted);margin-top:4px">Compliant</div>
    </div>
    <div style="background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:20px 28px;text-align:center;min-width:120px">
      <div style="font-size:28px;margin-bottom:8px">🔐</div>
      <div style="font-family:var(--mono);font-size:11px;color:#fff;font-weight:600">256-bit TLS</div>
      <div style="font-size:10px;color:var(--muted);margin-top:4px">Encryption</div>
    </div>
    <div style="background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:20px 28px;text-align:center;min-width:120px">
      <div style="font-size:28px;margin-bottom:8px">🏛️</div>
      <div style="font-family:var(--mono);font-size:11px;color:#fff;font-weight:600">HIPAA</div>
      <div style="font-size:10px;color:var(--muted);margin-top:4px">Ready</div>
    </div>
  </div>
  <p style="font-size:13px;color:var(--muted);max-width:500px;margin:0 auto">Your client data never trains AI models. All documents encrypted at rest and in transit. Full audit logs on every action.</p>
</section>

<!-- ROI CALCULATOR — like Harvey -->
<section style="position:relative;z-index:1;padding:60px 24px;max-width:800px;margin:0 auto">
  <div class="eyebrow">// roi calculator</div>
  <h2 class="section-h" style="font-size:clamp(24px,3vw,40px);margin-bottom:8px">See LexAI's impact <span style="color:var(--gold)">on your firm</span></h2>
  <p class="section-sub" style="margin-bottom:40px">How many lawyers in your firm?</p>
  <div style="background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:36px">
    <div style="display:flex;justify-content:space-between;margin-bottom:8px">
      <label style="font-size:13px;color:var(--muted)">Number of lawyers</label>
      <span id="roiLawyers" style="font-family:var(--mono);font-size:13px;color:var(--gold)">5</span>
    </div>
    <input type="range" min="1" max="100" value="5" id="roiSlider" style="width:100%;accent-color:var(--gold);margin-bottom:28px" oninput="calcROI(this.value)">
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
      <div style="background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:20px;text-align:center">
        <div style="font-family:var(--mono);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px">Hours saved / month</div>
        <div id="roiHours" style="font-family:var(--serif);font-size:32px;font-weight:900;color:#fff">100</div>
        <div style="font-size:11px;color:var(--muted);margin-top:4px">20hrs per lawyer</div>
      </div>
      <div style="background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:20px;text-align:center">
        <div style="font-family:var(--mono);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px">Value generated</div>
        <div id="roiValue" style="font-family:var(--serif);font-size:32px;font-weight:900;color:var(--gold)">$30K</div>
        <div style="font-size:11px;color:var(--muted);margin-top:4px">@ $300/hr billing rate</div>
      </div>
      <div style="background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:20px;text-align:center">
        <div style="font-family:var(--mono);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px">LexAI cost / month</div>
        <div id="roiCost" style="font-family:var(--serif);font-size:32px;font-weight:900;color:var(--green)">$1,500</div>
        <div style="font-size:11px;color:var(--muted);margin-top:4px">ROI: 20x return</div>
      </div>
    </div>
    <div style="text-align:center;margin-top:28px">
      <a href="/login" class="btn-gold">Start 7-Day Free Trial →</a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">
    <img src="/images/logo-icon.png" alt="LexAI" style="height:28px;width:28px;object-fit:contain;animation:heartbeat 2s ease-in-out infinite" onerror="this.style.display='none'">
    LexAI<em>.llc</em>
  </div>
  <div class="footer-copy">© 2026 LexAI.llc · Built in Bermuda 🇧🇲 · Dollar Double Empire · AI-Powered</div>
  <div class="footer-links">
    <a href="/privacy">Privacy</a>
    <a href="/terms">Terms</a>
    <a href="#affiliate">Affiliate</a>
    <a href="#templates">Templates</a>
    <a href="mailto:hello@lexai.llc">Contact</a>
  </div>
</footer>

<!-- SIGNUP GATE -->
<div id="signup-gate" style="display:none;position:fixed;inset:0;z-index:999;background:rgba(7,7,9,.92);backdrop-filter:blur(12px);align-items:center;justify-content:center;padding:24px">
  <div class="gate-card">
    <button onclick="closeGate()" style="position:absolute;top:16px;right:16px;background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer">×</button>
    <div style="font-family:var(--mono);font-size:11px;color:var(--gold);text-transform:uppercase;letter-spacing:.18em;margin-bottom:16px">// free preview complete</div>
    <div style="font-family:var(--serif);font-size:32px;font-weight:900;color:#fff;line-height:1.1;margin-bottom:12px">Your document<br>is <span style="color:var(--gold)">ready.</span></div>
    <p style="font-size:13px;color:var(--muted);margin-bottom:28px;line-height:1.7">Create your free account to download, access all 16 AI legal features, and search 4M+ real court cases.</p>
    <a href="/login" style="display:block;background:var(--gold);color:#070709;padding:14px;border-radius:8px;font-size:14px;font-weight:700;text-decoration:none;margin-bottom:12px">Create Free Account →</a>
    <a href="/login" style="display:block;background:transparent;color:var(--muted);padding:12px;border-radius:8px;font-size:13px;text-decoration:none;border:1px solid rgba(255,255,255,.07)">Already have an account? Sign in</a>
  </div>
</div>

<!-- AI CHAT WIDGET -->
<div class="ai-chat-float">
  <div class="chat-window" id="chatWindow">
    <div class="chat-head">
      <div class="chat-head-info">
        <div class="chat-avatar-sm">⚖️</div>
        <div>
          <div class="chat-head-name">LexAI Assistant</div>
          <div class="chat-head-status">● Online · AI-powered</div>
        </div>
      </div>
      <button class="chat-close" onclick="toggleChat()">×</button>
    </div>
    <div class="chat-msgs" id="chatMsgs">
      <div class="chat-msg bot">Hi! I'm your LexAI assistant. I can help you with contract questions, case law, legal research, or anything about the platform. What do you need?</div>
    </div>
    <div class="chat-suggestions" id="chatSugs">
      <span class="chat-sug" onclick="sendSug(this)">What jurisdictions do you cover?</span>
      <span class="chat-sug" onclick="sendSug(this)">How does self-learning work?</span>
      <span class="chat-sug" onclick="sendSug(this)">Bermuda court formats?</span>
    </div>
    <div class="chat-typing" id="chatTyping"><span></span><span></span><span></span></div>
    <div class="chat-input-row">
      <input type="text" id="chatInput" placeholder="Ask me anything legal..." onkeydown="if(event.key==='Enter')sendChat()">
      <button class="chat-send" onclick="sendChat()">→</button>
    </div>
  </div>
  <button class="chat-trigger" onclick="toggleChat()" id="chatTrigger" title="Chat with LexAI">⚖️</button>
</div>

<script>
// GATE
function showSignupGate(){const g=document.getElementById('signup-gate');g.style.display='flex';document.body.style.overflow='hidden'}
function closeGate(){document.getElementById('signup-gate').style.display='none';document.body.style.overflow=''}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeGate()})

// CASE LAW
async function searchCases(){
  const query=document.getElementById('cl-query').value.trim();
  if(!query)return;
  const btn=document.getElementById('cl-btn');
  const loading=document.getElementById('cl-loading');
  const results=document.getElementById('cl-results');
  const jurisdiction=document.getElementById('cl-jurisdiction').value;
  const area=document.getElementById('cl-area').value;
  const limit=document.getElementById('cl-limit').value;
  btn.disabled=true;btn.textContent='Searching...';
  loading.style.display='block';results.classList.remove('show');results.innerHTML='';
  try{
    const res=await fetch('/api/caselaw',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({query,jurisdiction,area_of_law:area,limit:parseInt(limit)})});
    const data=await res.json();
    if(res.status===401){showSignupGate();return;}
    if(data.cases?.length){
      results.innerHTML=`<div style="font-family:var(--mono);font-size:11px;color:var(--muted);margin-bottom:14px">Found ${data.total_found?.toLocaleString()||data.cases.length}+ cases · Sources: ${data.sources?.join(', ')}</div>`;
      data.cases.forEach(c=>{results.innerHTML+=`<div class="case-card"><div class="case-name">${c.case_name}</div><div class="case-meta">${c.citation||''} · ${c.court||''} · ${c.date_decided||''}</div><div class="case-excerpt">${c.excerpt||'No excerpt available'}</div><a href="${c.url}" target="_blank" style="color:var(--gold);text-decoration:none;font-size:11px;font-family:var(--mono)">View full opinion →</a><span class="case-source">${c.source}</span></div>`;});
    }else{results.innerHTML=`<div style="text-align:center;padding:20px;font-family:var(--mono);font-size:12px;color:var(--muted)">No cases found. Try a broader search.</div>`;}
    results.classList.add('show');
  }catch{showSignupGate();}
  btn.disabled=false;btn.textContent='Search Case Law →';loading.style.display='none';
}
document.getElementById('cl-query').addEventListener('keydown',e=>{if(e.key==='Enter')searchCases()});

// CHECKOUT
async function checkout(plan){
  try{
    const res=await fetch('/api/payments/checkout',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({plan})});
    const data=await res.json();
    if(data.url)window.location.href=data.url;
    else window.location.href='/login?next=pricing';
  }catch{window.location.href='/login?next=pricing';}
}

// ROI CALCULATOR
function calcROI(val) {
  const n = parseInt(val);
  document.getElementById('roiLawyers').textContent = n;
  const hours = n * 20;
  const value = n * 20 * 300;
  const cost = n * 300;
  const roi = Math.round(value / cost);
  document.getElementById('roiHours').textContent = hours.toLocaleString();
  document.getElementById('roiValue').textContent = '$' + (value >= 1000 ? Math.round(value/1000) + 'K' : value);
  document.getElementById('roiCost').textContent = '$' + cost.toLocaleString();
  const costEl = document.getElementById('roiCost').nextElementSibling;
  if(costEl) costEl.textContent = 'ROI: ' + roi + 'x return';
}

// EARNINGS CALCULATOR
function calcEarnings(val) {
  const n = parseInt(val);
  document.getElementById('refCount').textContent = n;
  const monthly = n * 60;
  const yearly = monthly * 12;
  document.getElementById('monthlyEarn').textContent = '$' + monthly.toLocaleString();
  document.getElementById('monthlyDetail').textContent = '($60/lawyer × ' + n + ' referral' + (n>1?'s':'') + ')';
  document.getElementById('yearlyEarn').textContent = '$' + yearly.toLocaleString();
}

// AI CHAT
let chatOpen=false;
function toggleChat(){
  chatOpen=!chatOpen;
  document.getElementById('chatWindow').classList.toggle('open',chatOpen);
}

function addMsg(text,role){
  const msgs=document.getElementById('chatMsgs');
  const sugs=document.getElementById('chatSugs');
  if(sugs)sugs.style.display='none';
  const div=document.createElement('div');
  div.className=`chat-msg ${role}`;
  div.textContent=text;
  msgs.appendChild(div);
  msgs.scrollTop=msgs.scrollHeight;
}

function showTyping(show){
  const t=document.getElementById('chatTyping');
  t.style.display=show?'flex':'none';
  if(show)document.getElementById('chatMsgs').scrollTop=document.getElementById('chatMsgs').scrollHeight;
}

async function sendChat(){
  const input=document.getElementById('chatInput');
  const msg=input.value.trim();
  if(!msg)return;
  input.value='';
  addMsg(msg,'user');
  showTyping(true);
  try{
    const res=await fetch('/api/ai/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:msg,context:'lexai_landing'})});
    const data=await res.json();
    showTyping(false);
    addMsg(data.reply||data.response||"I can help with that. Sign in to access full legal AI capabilities.",'bot');
  }catch{
    showTyping(false);
    addMsg("I'm having trouble connecting. Sign in to access full LexAI capabilities.",'bot');
  }
}

function sendSug(el){
  document.getElementById('chatInput').value=el.textContent;
  sendChat();
}
</script>
</body>
</html>
