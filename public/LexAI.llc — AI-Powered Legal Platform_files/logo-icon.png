<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="description" content="LexAI.llc — The world's most advanced AI legal platform. Advanced AI contract analysis, case law research, litigation prediction and self-learning AI. Built for Bermuda, Caribbean & Commonwealth.">
<meta property="og:title" content="LexAI.llc — AI-Powered Legal Platform">
<meta property="og:description" content="The world's most advanced AI legal platform. Built for everyone. Bermuda, Caribbean & Commonwealth jurisdiction depth no other platform offers.">
<title>LexAI.llc — AI-Powered Legal Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#070709;--s1:#0f0f12;--s2:#16161a;--s3:#1e1e24;
  --border:rgba(212,175,55,.1);--border2:rgba(212,175,55,.2);
  --gold:#d4af37;--gold2:#f0d060;--gold3:rgba(212,175,55,.08);
  --text:#ece9e0;--muted:#7a766c;--dim:#4a4740;
  --red:#ef4444;--green:#22c55e;--blue:#3b82f6;--cyan:#06b6d4;--purple:#8b5cf6;
  --serif:'Playfair Display',Georgia,serif;
  --sans:'Inter',system-ui,sans-serif;
  --mono:'JetBrains Mono',monospace;
  
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
body{background:var(--bg);color:var(--text);font-family:var(--sans);overflow-x:hidden;font-size:15px;line-height:1.6}
body::before{content:'';position:fixed;inset:0;background-image:radial-gradient(circle,rgba(212,175,55,.04) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;z-index:0}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 60px;height:64px;background:rgba(7,7,9,.95);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-logo{font-family:var(--serif);font-size:20px;font-weight:900;color:#fff;text-decoration:none;letter-spacing:-.01em;display:flex;align-items:center;gap:10px}
.nav-logo-img{height:40px;width:40px;object-fit:contain;animation:heartbeat 2s ease-in-out infinite}
@keyframes heartbeat{0%{transform:scale(1)}14%{transform:scale(1.15)}28%{transform:scale(1)}42%{transform:scale(1.08)}56%{transform:scale(1)}100%{transform:scale(1)}}
.nav-logo em{color:var(--gold);font-style:normal}
.nav-links{display:flex;align-items:center;gap:28px;list-style:none}
.nav-links a{color:var(--muted);text-decoration:none;font-size:13px;font-weight:500;transition:color .15s}
.nav-links a:hover{color:var(--text)}
.nav-btn{background:var(--gold)!important;color:#070709!important;padding:8px 20px;border-radius:6px;font-weight:600!important;font-size:13px!important}
.nav-btn:hover{background:var(--gold2)!important}

/* HERO */
.hero{position:relative;z-index:1;min-height:100vh;display:flex;align-items:center;justify-content:flex-start;padding:0;overflow:hidden}
.hero-photo-bg{position:absolute;inset:0;background-image:url('/hero-bg.jpg');background-size:120%;background-position:60% 20%;z-index:0;animation:kenburns 22s ease-in-out infinite alternate}@keyframes kenburns{0%{background-size:120%;background-position:60% 20%}50%{background-size:130%;background-position:50% 30%}100%{background-size:120%;background-position:62% 15%}}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(100deg,rgba(5,4,10,.97) 0%,rgba(5,4,10,.93) 32%,rgba(5,4,10,.65) 58%,rgba(5,4,10,.15) 78%,transparent 100%);z-index:1}
.hero-fade-top{position:absolute;top:0;left:0;right:0;height:140px;background:linear-gradient(rgba(5,4,10,.75),transparent);z-index:1}
.hero-fade-bot{position:absolute;bottom:0;left:0;right:0;height:180px;background:linear-gradient(transparent,rgba(5,4,10,.99));z-index:1}
.hero-glow{position:absolute;top:5%;right:22%;width:480px;height:480px;background:radial-gradient(circle,rgba(212,175,55,.09),transparent 65%);z-index:1;pointer-events:none}
.hero-dots{position:absolute;inset:0;background-image:radial-gradient(circle,rgba(212,175,55,.04) 1px,transparent 1px);background-size:28px 28px;z-index:2;pointer-events:none}
.hero-inner{position:relative;z-index:10;padding:140px 60px 100px 64px;max-width:680px;text-align:left}
.hcite{position:absolute;z-index:20;pointer-events:none}
.hc-card{background:rgba(5,4,10,.83);border:1px solid rgba(212,175,55,.22);border-radius:9px;padding:11px 15px;backdrop-filter:blur(12px);box-shadow:0 8px 32px rgba(0,0,0,.4)}
.hc-label{font-family:var(--mono);font-size:9px;color:rgba(212,175,55,.55);text-transform:uppercase;letter-spacing:.12em;margin-bottom:5px}
.hc-text{font-family:var(--mono);font-size:11px;color:rgba(236,233,224,.92)}
.hc-tag{display:inline-block;margin-top:6px;font-size:9px;font-family:var(--mono);padding:2px 8px;border-radius:3px}
.tag-g{background:rgba(34,197,94,.08);color:#4ade80;border:1px solid rgba(34,197,94,.2)}
.tag-a{background:rgba(212,175,55,.08);color:#d4af37;border:1px solid rgba(212,175,55,.2)}
.tag-r{background:rgba(239,68,68,.08);color:#f87171;border:1px solid rgba(239,68,68,.2)}
.hcite{max-width:220px}
.hcite1{top:10%;right:2%;animation:rot1 11s ease-in-out infinite}
.hcite2{top:42%;right:1%;animation:rot2 14s ease-in-out infinite .6s}
.hcite3{bottom:18%;right:4%;animation:rot3 10s ease-in-out infinite 1.2s}
.hcite4{top:24%;right:18%;animation:rot1 13s ease-in-out infinite 2s}
@media(max-width:1100px){.hcite4{display:none}}
@media(max-width:900px){.hcite1,.hcite2,.hcite3,.hcite4{display:none}}
@keyframes rot1{0%{transform:translateY(0) rotate(-2deg)}25%{transform:translateY(-12px) rotate(3deg)}50%{transform:translateY(-5px) rotate(-1deg)}75%{transform:translateY(-14px) rotate(4deg)}100%{transform:translateY(0) rotate(-2deg)}}
@keyframes rot2{0%{transform:translateY(0) rotate(2deg)}30%{transform:translateY(-10px) rotate(-4deg)}65%{transform:translateY(-6px) rotate(3deg)}100%{transform:translateY(0) rotate(2deg)}}
@keyframes rot3{0%{transform:translateY(0) rotate(-1deg)}20%{transform:translateY(-8px) rotate(4deg)}55%{transform:translateY(-14px) rotate(-3deg)}80%{transform:translateY(-4px) rotate(2deg)}100%{transform:translateY(0) rotate(-1deg)}}
.hero-badge{display:inline-flex;align-items:center;gap:10px;background:var(--gold3);border:1px solid var(--border2);border-radius:100px;padding:7px 18px;font-family:var(--mono);font-size:11px;color:var(--gold);letter-spacing:.1em;margin-bottom:32px;animation:rise .5s ease both}
.val-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes rise{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.hero h1{font-family:var(--serif);font-size:clamp(44px,8vw,90px);font-weight:900;line-height:1.0;letter-spacing:-.04em;color:#fff;max-width:1000px;margin-bottom:28px;animation:rise .6s .1s ease both}
.hero h1 .gold{color:var(--gold)}
.hero h1 .italic{font-style:italic;color:rgba(255,255,255,.7)}
.hero-sub{font-size:clamp(15px,2vw,18px);color:var(--muted);max-width:580px;line-height:1.7;font-weight:300;margin-bottom:44px;animation:rise .6s .2s ease both}
.hero-ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:56px;animation:rise .6s .3s ease both}
.btn-gold{background:var(--gold);color:#070709;padding:14px 34px;border-radius:8px;font-size:14px;font-weight:700;text-decoration:none;transition:all .2s;display:inline-block;letter-spacing:.01em;border:none;cursor:pointer;font-family:var(--sans)}
.btn-gold:hover{background:var(--gold2);transform:translateY(-1px)}
.btn-ghost{background:transparent;color:var(--text);padding:14px 34px;border-radius:8px;font-size:14px;font-weight:500;border:1px solid rgba(255,255,255,.1);text-decoration:none;transition:all .2s;display:inline-block}
.btn-ghost:hover{border-color:rgba(255,255,255,.25);background:rgba(255,255,255,.03)}
.hero-stats{display:flex;gap:0;animation:rise .6s .4s ease both;border:1px solid var(--border);border-radius:10px;overflow:hidden}
.hstat{padding:14px 28px;text-align:center;border-right:1px solid var(--border)}
.hstat:last-child{border-right:none}
.hstat-val{font-family:var(--serif);font-size:22px;font-weight:900;color:#fff}
.hstat-label{font-size:11px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.06em;margin-top:2px}

/* TRUST BADGES */
.trust-bar{position:relative;z-index:1;border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--s1);padding:20px 60px;display:flex;align-items:center;justify-content:center;gap:48px;flex-wrap:wrap}
.trust-label{font-family:var(--mono);font-size:10px;color:var(--dim);text-transform:uppercase;letter-spacing:.12em;flex-shrink:0}
.trust-badge{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:12px;color:var(--muted);font-weight:500;transition:color .15s}
.trust-badge:hover{color:var(--text)}
.trust-badge svg{opacity:.6}
.nvidia-badge{color:var(--gold)!important;border:1px solid rgba(212,175,55,.2);border-radius:6px;padding:4px 10px;font-size:11px}
.nvidia-badge svg{opacity:1}

/* GPU SECTION */
.gpu-section{position:relative;z-index:1;padding:80px 24px;max-width:1100px;margin:0 auto;text-align:center}
.gpu-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px}
.gpu-card{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:28px;text-align:left;position:relative;overflow:hidden}
.gpu-card::before{content:'';position:absolute;top:0;right:0;width:120px;height:120px;background:radial-gradient(circle,rgba(212,175,55,.04),transparent 70%)}
.gpu-icon{font-size:24px;margin-bottom:14px}
.gpu-t{font-family:var(--serif);font-size:18px;font-weight:700;color:#fff;margin-bottom:8px}
.gpu-d{font-size:12px;color:var(--muted);line-height:1.6}
.gpu-stat{font-family:var(--mono);font-size:11px;color:var(--gold);margin-top:12px;display:flex;align-items:center;gap:6px}
.gpu-stat::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0}

/* MARQUEE */
.marquee-wrap{border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--s1);padding:13px 0;overflow:hidden;position:relative;z-index:1}
.marquee-inner{display:flex;animation:scroll 35s linear infinite;white-space:nowrap}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.mitem{font-family:var(--mono);font-size:11px;color:var(--muted);padding:0 36px;text-transform:uppercase;letter-spacing:.1em}
.mitem b{color:var(--gold);margin-right:12px}

/* SECTIONS */
.section{position:relative;z-index:1;padding:100px 24px;max-width:1100px;margin:0 auto}
.eyebrow{font-family:var(--mono);font-size:11px;color:var(--gold);text-transform:uppercase;letter-spacing:.18em;text-align:center;margin-bottom:14px}
.section-h{font-family:var(--serif);font-size:clamp(30px,5vw,52px);font-weight:900;text-align:center;letter-spacing:-.03em;line-height:1.1;margin-bottom:12px;color:#fff}
.section-sub{text-align:center;font-size:15px;color:var(--muted);max-width:540px;margin:0 auto 56px;line-height:1.7}

/* WHO IS IT FOR */
.user-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:48px}
.user-card{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:28px 20px;text-align:center;cursor:pointer;transition:all .2s}
.user-card:hover{border-color:var(--gold);background:var(--gold3);transform:translateY(-4px)}
.user-icon{font-size:36px;margin-bottom:16px}
.user-t{font-family:var(--serif);font-size:16px;font-weight:700;color:#fff;margin-bottom:8px}
.user-d{font-size:12px;color:var(--muted);line-height:1.6}
.user-link{display:inline-block;margin-top:12px;font-size:11px;font-family:var(--mono);color:var(--gold);text-decoration:none;letter-spacing:.06em}

/* FEAT GRID */
.feat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border)}
.feat{background:var(--bg);padding:28px 24px;transition:background .15s;cursor:default}
.feat:hover{background:var(--s1)}
.feat-n{font-family:var(--mono);font-size:10px;color:var(--dim);margin-bottom:16px;letter-spacing:.06em}
.feat-t{font-family:var(--serif);font-size:17px;font-weight:700;color:#fff;margin-bottom:8px;line-height:1.2}
.feat-d{font-size:12px;color:var(--muted);line-height:1.6}
.feat-badge{display:inline-block;font-size:9px;font-family:var(--mono);padding:2px 8px;border-radius:3px;margin-top:10px;text-transform:uppercase;letter-spacing:.06em}
.badge-new{background:rgba(212,175,55,.1);color:var(--gold);border:1px solid var(--border)}
.badge-pro{background:rgba(139,92,246,.1);color:#a78bfa;border:1px solid rgba(139,92,246,.2)}
.badge-gpu{background:rgba(212,175,55,.1);color:var(--gold);border:1px solid rgba(212,175,55,.2)}

/* TEMPLATES */
.tpl-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:48px}
.tpl-card{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:20px;transition:all .2s;cursor:pointer;text-decoration:none;display:block}
.tpl-card:hover{border-color:var(--gold);background:var(--gold3);transform:translateY(-2px)}
.tpl-icon{font-size:24px;margin-bottom:10px}
.tpl-t{font-family:var(--serif);font-size:15px;font-weight:700;color:#fff;margin-bottom:4px}
.tpl-meta{font-size:11px;color:var(--muted);font-family:var(--mono);display:flex;align-items:center;justify-content:space-between}
.tpl-free{color:var(--green);font-size:10px;font-family:var(--mono);border:1px solid rgba(34,197,94,.2);border-radius:3px;padding:1px 6px}

/* CASE LAW */
.caselaw-demo{background:var(--s1);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-top:60px}
.demo-bar{background:var(--s2);padding:14px 20px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border)}
.dbar-dot{width:10px;height:10px;border-radius:50%}
.dbar-title{font-family:var(--mono);font-size:11px;color:var(--muted);flex:1;text-align:center}
.demo-body{padding:28px}
.demo-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px}
.demo-field label{display:block;font-size:10px;font-family:var(--mono);color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px}
.demo-field select,.demo-field input{width:100%;background:var(--s3);border:1px solid rgba(255,255,255,.05);border-radius:6px;color:var(--text);font-size:13px;padding:9px 12px;outline:none;font-family:var(--sans);transition:border-color .15s;-webkit-appearance:none}
.demo-field select:focus,.demo-field input:focus{border-color:var(--gold)}
.search-btn{width:100%;background:var(--gold);color:#070709;border:none;border-radius:7px;padding:12px;font-size:14px;font-weight:700;cursor:pointer;font-family:var(--sans);margin-bottom:20px;transition:all .2s}
.search-btn:hover{background:var(--gold2)}
.search-btn:disabled{opacity:.5;cursor:not-allowed}
.case-results{display:none}
.case-results.show{display:block}
.case-card{background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:10px}
.case-name{font-weight:600;color:#fff;font-size:14px;margin-bottom:4px}
.case-meta{font-family:var(--mono);font-size:11px;color:var(--muted);margin-bottom:8px}
.case-excerpt{font-size:12px;color:rgba(236,233,224,.7);line-height:1.6}
.case-source{display:inline-block;font-size:10px;font-family:var(--mono);padding:2px 8px;border-radius:3px;margin-top:8px;border:1px solid var(--border);color:var(--muted)}
.loading-msg{font-family:var(--mono);font-size:12px;color:var(--gold);text-align:center;padding:20px;display:none}

/* TESTIMONIALS */
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:56px}
.test-card{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:28px}
.test-stars{color:var(--gold);font-size:14px;margin-bottom:16px;letter-spacing:2px}
.test-quote{font-size:13px;color:rgba(236,233,224,.8);line-height:1.7;font-style:italic;margin-bottom:20px}
.test-author{display:flex;align-items:center;gap:12px}
.test-avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--gold),rgba(212,175,55,.3));display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-weight:900;font-size:14px;color:#070709;flex-shrink:0}
.test-name{font-size:13px;font-weight:600;color:#fff}
.test-role{font-size:11px;color:var(--muted);font-family:var(--mono)}
.test-earn{color:var(--green);font-size:11px;font-family:var(--mono);margin-top:2px}

/* LEARNING */
.learning-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:56px}
.learn-card{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:28px}
.learn-icon{font-size:28px;margin-bottom:14px}
.learn-t{font-family:var(--serif);font-size:18px;font-weight:700;color:#fff;margin-bottom:8px}
.learn-d{font-size:13px;color:var(--muted);line-height:1.7}
.learn-steps{margin-top:16px;list-style:none}
.learn-steps li{font-size:12px;color:var(--muted);padding:5px 0;display:flex;gap:8px;align-items:flex-start;border-bottom:1px solid rgba(255,255,255,.04)}
.learn-steps li:last-child{border-bottom:none}
.learn-steps li::before{content:'→';color:var(--gold);flex-shrink:0;font-family:var(--mono);font-size:11px;margin-top:1px}

/* PRICING */
.pricing-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:56px;align-items:start}
.p-card{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:28px 22px;display:flex;flex-direction:column;position:relative}
.p-card.pop{border-color:var(--gold)}
.pop-pill{position:absolute;top:-11px;left:50%;transform:translateX(-50%);background:var(--gold);color:#070709;font-size:10px;font-weight:700;padding:3px 14px;border-radius:100px;font-family:var(--mono);letter-spacing:.05em;white-space:nowrap}
.p-plan{font-family:var(--mono);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em;margin-bottom:10px}
.p-price{font-family:var(--serif);font-size:40px;font-weight:900;color:#fff}
.p-price sup{font-size:16px;color:var(--muted);font-family:var(--sans);font-weight:400;vertical-align:super}
.p-period{font-size:12px;color:var(--muted);font-family:var(--sans)}
.p-tagline{font-size:12px;color:var(--muted);margin:10px 0 18px;padding-bottom:18px;border-bottom:1px solid var(--border);line-height:1.5}
.p-feats{list-style:none;flex:1;margin-bottom:22px}
.p-feats li{font-size:12px;color:var(--text);padding:5px 0;display:flex;gap:8px;align-items:flex-start;line-height:1.4}
.p-feats li::before{content:'—';color:var(--gold);font-family:var(--mono);flex-shrink:0}
.p-cta{display:block;text-align:center;padding:11px;border-radius:7px;font-size:13px;font-weight:600;text-decoration:none;cursor:pointer;border:none;font-family:var(--sans);transition:all .2s}
.pcta-gold{background:var(--gold);color:#070709}
.pcta-gold:hover{background:var(--gold2)}
.pcta-outline{background:transparent;color:var(--text);border:1px solid rgba(255,255,255,.1)}
.pcta-outline:hover{border-color:rgba(255,255,255,.25)}

/* VS TABLE */
.vs-section{position:relative;z-index:1;padding:60px 24px;max-width:900px;margin:0 auto;text-align:center}
.vs-table{width:100%;border-collapse:collapse;margin-top:40px;font-size:13px}
.vs-table th{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.08em;padding:12px 16px;border-bottom:1px solid var(--border);color:var(--muted)}
.vs-table th.ours{color:var(--gold)}
.vs-table td{padding:12px 16px;border-bottom:1px solid rgba(255,255,255,.04);text-align:center}
.vs-table td:first-child{text-align:left;color:var(--text)}
.vs-check{color:var(--green)}
.vs-x{color:var(--red)}
.vs-partial{color:var(--gold);font-size:12px}

/* AFFILIATE */
.affiliate-section{position:relative;z-index:1;padding:80px 24px;max-width:900px;margin:0 auto}
.aff-card{background:linear-gradient(135deg,rgba(212,175,55,.08),rgba(212,175,55,.03));border:1px solid var(--border2);border-radius:16px;padding:48px;text-align:center}
.aff-title{font-family:var(--serif);font-size:36px;font-weight:900;color:#fff;margin-bottom:12px}
.aff-sub{font-size:15px;color:var(--muted);max-width:500px;margin:0 auto 32px;line-height:1.7}
.aff-stats{display:flex;justify-content:center;gap:48px;margin-bottom:36px}
.aff-stat-val{font-family:var(--serif);font-size:32px;font-weight:900;color:var(--gold)}
.aff-stat-label{font-size:12px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;letter-spacing:.06em;margin-top:4px}

/* MOBILE PWA */
.pwa-section{position:relative;z-index:1;padding:80px 24px;max-width:1000px;margin:0 auto}
.pwa-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
.pwa-badge{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--border);border-radius:10px;padding:12px 20px;font-size:13px;color:var(--text);text-decoration:none;transition:all .2s;margin-right:12px}
.pwa-badge:hover{border-color:var(--gold);color:var(--gold)}
.device-mockup{background:var(--s1);border:1px solid var(--border);border-radius:20px;padding:24px;font-family:var(--mono);font-size:11px;color:var(--muted)}

/* SECURITY */
.sec-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:40px}

/* AI CHAT WIDGET */
.ai-chat-float{position:fixed;bottom:28px;right:28px;z-index:500}
.chat-trigger{width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,var(--gold),rgba(212,175,55,.6));border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:24px;box-shadow:0 4px 24px rgba(212,175,55,.3);transition:all .2s;animation:heartbeat 2s ease-in-out infinite}
.chat-trigger:hover{transform:scale(1.08)}
.chat-window{position:absolute;bottom:72px;right:0;width:360px;background:var(--s1);border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,.5);transform:scale(0);transform-origin:bottom right;transition:transform .25s cubic-bezier(.34,1.56,.64,1);display:flex;flex-direction:column;max-height:480px}
.chat-window.open{transform:scale(1)}
.chat-head{background:var(--s2);padding:14px 18px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)}
.chat-head-info{display:flex;align-items:center;gap:10px}
.chat-avatar-sm{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--gold),rgba(212,175,55,.4));display:flex;align-items:center;justify-content:center;font-size:18px}
.chat-head-name{font-size:13px;font-weight:600;color:#fff}
.chat-head-status{font-size:11px;color:var(--green);font-family:var(--mono)}
.chat-close{background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;line-height:1;padding:4px}
.chat-msgs{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px}
.chat-msg{max-width:85%;font-size:13px;line-height:1.5;padding:10px 13px;border-radius:12px}
.chat-msg.bot{background:var(--s3);color:var(--text);border-radius:12px 12px 12px 3px;align-self:flex-start}
.chat-msg.user{background:var(--gold);color:#070709;border-radius:12px 12px 3px 12px;align-self:flex-end;font-weight:500}
.chat-typing{display:flex;gap:4px;padding:10px 13px;background:var(--s3);border-radius:12px 12px 12px 3px;align-self:flex-start;display:none}
.chat-typing span{width:6px;height:6px;background:var(--muted);border-radius:50%;animation:typing .8s infinite}
.chat-typing span:nth-child(2){animation-delay:.15s}
.chat-typing span:nth-child(3){animation-delay:.3s}
@keyframes typing{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}
.chat-input-row{padding:12px;border-top:1px solid var(--border);display:flex;gap:8px}
.chat-input-row input{flex:1;background:var(--s3);border:1px solid rgba(255,255,255,.06);border-radius:8px;color:var(--text);font-size:13px;padding:9px 12px;outline:none;font-family:var(--sans)}
.chat-input-row input:focus{border-color:var(--gold)}
.chat-send{background:var(--gold);border:none;border-radius:8px;width:36px;height:36px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;color:#070709;font-weight:700}
.chat-send:hover{background:var(--gold2)}
.chat-suggestions{display:flex;flex-wrap:wrap;gap:6px;padding:0 16px 12px}
.chat-sug{font-size:11px;background:var(--s3);border:1px solid var(--border);border-radius:100px;padding:4px 10px;color:var(--muted);cursor:pointer;transition:all .15s;font-family:var(--mono)}
.chat-sug:hover{border-color:var(--gold);color:var(--gold)}

/* FOOTER */
footer{position:relative;z-index:1;border-top:1px solid var(--border);padding:40px 60px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}
.footer-logo{font-family:var(--serif);font-size:18px;font-weight:900;color:#fff;display:flex;align-items:center;gap:8px}
.footer-logo em{color:var(--gold);font-style:normal}
.footer-copy{font-size:11px;color:var(--muted);font-family:var(--mono)}
.footer-links{display:flex;gap:24px}
.footer-links a{font-size:11px;color:var(--muted);text-decoration:none;font-family:var(--mono);transition:color .15s}
.footer-links a:hover{color:var(--text)}

/* GATE MODAL */
#signup-gate{display:none;position:fixed;inset:0;z-index:999;background:rgba(7,7,9,.92);backdrop-filter:blur(12px);align-items:center;justify-content:center;padding:24px}
.gate-card{background:var(--s1);border:1px solid var(--gold);border-radius:14px;padding:44px 40px;max-width:460px;width:100%;text-align:center;position:relative}

@media(max-width:1024px){.feat-grid{grid-template-columns:repeat(2,1fr)}.pricing-grid{grid-template-columns:1fr 1fr}.user-grid{grid-template-columns:repeat(2,1fr)}.tpl-grid{grid-template-columns:repeat(2,1fr)}.gpu-grid{grid-template-columns:1fr 1fr}.test-grid{grid-template-columns:1fr}}
@media(max-width:768px){
  .nav{padding:0 20px}.nav-links{display:none}
  .hero-stats{flex-direction:column;border:none;gap:12px}.hstat{border:1px solid var(--border);border-radius:8px;border-right:1px solid var(--border)!important}
  .demo-row{grid-template-columns:1fr}
  .learning-grid{grid-template-columns:1fr}
  .feat-grid{grid-template-columns:1fr}
  .pricing-grid{grid-template-columns:1fr}
  .user-grid{grid-template-columns:1fr 1fr}
  .tpl-grid{grid-template-columns:1fr}
  .gpu-grid{grid-template-columns:1fr}
  .pwa-grid{grid-template-columns:1fr}
  .trust-bar{padding:16px 24px;gap:24px}
  footer{padding:32px 20px;flex-direction:column;text-align:center}.footer-links{justify-content:center}
  .chat-window{width:300px}
  .aff-stats{gap:24px}
}
</style>
</head>
