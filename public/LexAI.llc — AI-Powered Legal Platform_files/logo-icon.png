<!-- WHO IS IT FOR -->
<section class="section" id="for-you">
  <div class="eyebrow">// built for everyone in law</div>
  <h2 class="section-h">Who is <span style="color:var(--gold)">LexAI</span> for?</h2>
  <p class="section-sub">Whether you're a solo practitioner, a law firm, a student, or a business — LexAI adapts to your needs and jurisdiction.</p>
